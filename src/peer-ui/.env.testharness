# Used by `npm run dev:harness` (vite --mode testharness)
# Points the proxy at the first test-harness node (HTTP, no TLS) for the initial load
# before NodeSelector auto-selects a node.
PEER_CLIENT_API_URL=http://localhost:5001
PEER_METADATA_API_URL=http://localhost:5176
# Tells NodeSelector to show the node-switching dropdown and fetch from the harness API.
# Once a node is selected, client.ts bypasses the proxy and hits the node directly via CORS.
VITE_TEST_HARNESS_URL=http://localhost:5200
